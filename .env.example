# ─────────────────────────────────────────────────────────────────────────────
# Evo Hub <-> Chatwoot bridge — variáveis de ambiente (TEMPLATE)
# Copie para .env e preencha. NUNCA ponha segredo real aqui — este arquivo é versionado.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase self-host (ALVO: bancortovital.soberano.pro) ────────────────────
SUPABASE_URL=https://bancortovital.soberano.pro
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# connection string direta (migrations), ex.:
# postgresql://postgres:<senha>@bancortovital.soberano.pro:5432/postgres
SUPABASE_DB_URL=

# ── EVO Hub ──────────────────────────────────────────────────────────────────
EVOLUTION_HUB_URL=https://api.evohub.ai
EVOLUTION_HUB_FRONTEND_URL=https://app.evohub.ai      # base do link público /connect/<token>
EVOLUTION_HUB_API_KEY=evh_pk_xxxxxxxxxxxxxxxxxxxxxxxx  # API Key da conta no Hub
EVOLUTION_HUB_WEBHOOK_SECRET=                          # VOCÊ GERA (string aleatória forte). Não se busca em painel.

# ── Chatwoot ─────────────────────────────────────────────────────────────────
CHATWOOT_URL=https://app.chatwoot.com                 # base real do seu Chatwoot (self-host? cloud?)
CHATWOOT_ACCOUNT_ID=                                  # id numérico da conta
CHATWOOT_API_ACCESS_TOKEN=                            # token de agente/admin (Application API)
CHATWOOT_WEBHOOK_SECRET=                              # VOCÊ GERA (string aleatória forte). Não se busca em painel.

# ── Ponte (container Deno via Coolify) ───────────────────────────────────────
# Domínio público do serviço da ponte no Coolify. Rotas: /hub-webhook,
# /chatwoot-webhook, /connect-channel, /metrics-rollup. Ex.: https://cofre.camposoberano.com.br
BRIDGE_PUBLIC_BASE=https://cofre.camposoberano.com.br
SYNC_SECRET=                                         # opcional; se vazio, /sync-facebook usa CHATWOOT_WEBHOOK_SECRET
PORT=8000

# ── Opcional ─────────────────────────────────────────────────────────────────
COOLIFY_DEPLOY_HOOK=                                  # URL de redeploy do Coolify (gatilho), se for usar CI
