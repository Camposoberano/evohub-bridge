# ─────────────────────────────────────────────────────────────────────────────
# Evo Hub <-> Chatwoot bridge — variáveis de ambiente
# Copie para .env e preencha. NUNCA comite o .env real.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase self-host (ALVO: bancortovital.soberano.pro) ────────────────────
SUPABASE_URL=https://bancortovital.soberano.pro
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# connection string direta (migrations via CLI/psql), ex.:
# postgresql://postgres:<senha>@bancortovital.soberano.pro:5432/postgres
SUPABASE_DB_URL=

# ── EVO Hub ──────────────────────────────────────────────────────────────────
EVOLUTION_HUB_URL=https://api.evohub.ai
EVOLUTION_HUB_FRONTEND_URL=https://app.evohub.ai      # base do link público /connect/<token>
EVOLUTION_HUB_API_KEY=evh_pk_xxxxxxxxxxxxxxxxxxxxxxxx  # API Key da conta no Hub
EVOLUTION_HUB_WEBHOOK_SECRET=                          # segredo HMAC (Hub assina X-Hub-Signature-256)

# ── Chatwoot (cloud / fazer.ai) ──────────────────────────────────────────────
CHATWOOT_URL=https://app.chatwoot.com                 # ou host fazer.ai
CHATWOOT_ACCOUNT_ID=                                   # id numérico da conta
CHATWOOT_API_ACCESS_TOKEN=                            # token de agente/admin (Application API)
CHATWOOT_WEBHOOK_SECRET=                              # validar webhooks vindos do Chatwoot

# ── Ponte (container Deno via Coolify) ───────────────────────────────────────
# Domínio público do serviço da ponte no Coolify. Rotas: /hub-webhook,
# /chatwoot-webhook, /connect-channel, /metrics-rollup. Ex.: https://ponte.soberano.pro
# Estas mesmas variáveis precisam estar setadas no serviço do Coolify (runtime).
BRIDGE_PUBLIC_BASE=https://ponte.soberano.pro
PORT=8000
